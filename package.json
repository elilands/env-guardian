{
  "name": "env-guardian",
  "version": "1.0.0",
  "description": "A high-performance CLI for scanning, validating, and syncing .env files.",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "env-guardian": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "env",
    "dotenv",
    "cli",
    "validator",
    "security"
  ],
  "author": "GitHub Master",
  "license": "ISC",
  "dependencies": {
    "cac": "^7.0.0",
    "dotenv": "^17.3.1",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
